global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    tcp          # Indispensable pour PostgreSQL (pas du HTTP !)
    timeout connect 5s
    timeout client  50s
    timeout server  50s

# Statistiques HAProxy (pratique pour ton oral d'examen !)
listen stats
    bind *:8404
    mode http
    stats enable
    stats uri /monitor
    stats refresh 5s

# Frontend pour PostgreSQL
frontend pg_cluster
    bind *:5432
    default_backend pg_pool

# Backend distribuant le trafic
backend pg_pool
    balance roundrobin
    option tcp-check
    server pg-master 10.0.10.101:5432 check
    server pg-slave-1 10.0.10.102:5432 check
    server pg-slave-2 10.0.10.103:5432 check
